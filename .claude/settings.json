{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit-validate.sh",
            "timeout": 120,
            "if": "Bash(git commit*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-validate.sh",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(mvn compile*)",
      "Bash(mvn test*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git push*)",
      "Bash(git add *)",
      "Bash(git commit*)"
    ]
  }
}
